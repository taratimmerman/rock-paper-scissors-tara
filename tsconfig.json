{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["jest", "node"],
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": [
    "src",
    "**/*.test.ts",
    "**/*.test.tsx",
    "playwright.config.ts",
    "tests/**/*.ts"
  ]
}
